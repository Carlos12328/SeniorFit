{
  "info": { "name": "SeniorFit MVP Testável", "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json" },
  "variable": [ { "key": "baseUrl", "value": "http://localhost:3000" }, { "key": "adminToken", "value": "" }, { "key": "anaToken", "value": "" }, { "key": "profissionalToken", "value": "" } ],
  "item": [
    { "name": "Login Admin - sucesso", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "url": "{{baseUrl}}/login", "body": { "mode": "raw", "raw": "{\"email\":\"admin@seniorfit.com\",\"senha\":\"123456\"}" } }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('status 200', () => pm.response.to.have.status(200));", "pm.collectionVariables.set('adminToken', pm.response.json().dados.token);"] } }] },
    { "name": "Login inválido - erro", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "url": "{{baseUrl}}/login", "body": { "mode": "raw", "raw": "{\"email\":\"admin@seniorfit.com\",\"senha\":\"errada123\"}" } }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('status 401', () => pm.response.to.have.status(401));", "pm.test('erro padronizado', () => pm.expect(pm.response.json().codigoErro).to.eql('CREDENCIAIS_INVALIDAS'));"] } }] },
    { "name": "Listar idosos como Admin", "request": { "method": "GET", "header": [{"key":"Authorization","value":"Bearer {{adminToken}}"}], "url": "{{baseUrl}}/idosos" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('status 200', () => pm.response.to.have.status(200));", "pm.test('retorna lista', () => pm.expect(pm.response.json().dados.length).to.be.above(0));"] } }] },
    { "name": "Criar idoso como Admin", "request": { "method": "POST", "header": [{"key":"Authorization","value":"Bearer {{adminToken}}"},{"key":"Content-Type","value":"application/json"}], "url": "{{baseUrl}}/idosos", "body": { "mode": "raw", "raw": "{\"nome\":\"Postman Idoso\",\"idade\":75,\"idAcompanhante\":2}" } }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('status 201', () => pm.response.to.have.status(201));"] } }] },
    { "name": "Criar atividade duração inválida", "request": { "method": "POST", "header": [{"key":"Authorization","value":"Bearer {{adminToken}}"},{"key":"Content-Type","value":"application/json"}], "url": "{{baseUrl}}/atividades", "body": { "mode": "raw", "raw": "{\"idIdoso\":1,\"tipo\":\"Caminhada\",\"duracao\":481,\"dataAtividade\":\"2026-05-26\"}" } }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('status 400', () => pm.response.to.have.status(400));", "pm.test('BVA2 duração máxima', () => pm.expect(pm.response.json().codigoErro).to.eql('DURACAO_INVALIDA_MAXIMA'));"] } }] },
    { "name": "Frequência semanal", "request": { "method": "GET", "header": [{"key":"Authorization","value":"Bearer {{adminToken}}"}], "url": "{{baseUrl}}/frequencia?idIdoso=1&periodo=semana" }, "event": [{ "listen": "test", "script": { "exec": ["pm.test('status 200', () => pm.response.to.have.status(200));", "pm.test('tem métricas', () => pm.expect(pm.response.json().dados.frequencia).to.have.property('total'));"] } }] }
  ]
}
